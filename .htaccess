# /public/.htaccess
Options -Indexes
RewriteEngine On

# ── Protege pasta /app ─────────────────────────────────────────────────────────
RewriteRule ^app/ - [F,L]

# ── Remove .php das URLs ───────────────────────────────────────────────────────

# 1. Se alguém acessar /pagina.php, redireciona 301 para /pagina
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2. Se o arquivo /pagina.php existir, serve sem mostrar o .php na URL
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)/?$ $1.php [L,QSA]

# 3. Fallback: encaminha para index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]